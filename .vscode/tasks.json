{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "fullstack:startup-dashboard",
      "type": "shell",
      "command": "./.devcontainer/scripts/startup-dashboard.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "showReuseMessage": false,
        "close": false
      }
    }
  ]
}
