{
  "name": "interop-dashboard-frontend",
  "version": "2.3.0-RC2",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "build-dev": "tsc -p tsconfig.app.json && vite build --mode development",
    "preview": "vite build --mode development && vite preview --mode development",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "generate-types": "node scripts/open-api-type-generator.js",
    "crawling-guide-links": "node scripts/guide-crawl/index.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@date-io/date-fns": "2.17.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/base": "5.0.0-beta.70",
    "@mui/icons-material": "5.18.0",
    "@mui/lab": "5.0.0-alpha.177",
    "@mui/material": "5.18.0",
    "@mui/system": "5.18.0",
    "@mui/x-date-pickers": "6.20.2",
    "@pagopa/interop-fe-commons": "1.5.3",
    "@pagopa/mui-italia": "2.4.0",
    "@tanstack/react-query": "5.51.4",
    "@tanstack/react-query-devtools": "5.51.4",
    "autosuggest-highlight": "3.3.4",
    "axios": "1.15.2",
    "date-fns": "2.30.0",
    "i18next": "23.16.8",
    "jwt-decode": "4.0.0",
    "lodash": "4.18.1",
    "mixpanel-browser": "2.75.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "4.1.2",
    "react-hook-form": "7.46.1",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.4.3",
    "ts-pattern": "5.9.0",
    "zod": "4.3.6",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@mui/utils": "7.3.8",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "14.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/autosuggest-highlight": "3.2.3",
    "@types/lodash": "4.17.24",
    "@types/mixpanel-browser": "2.66.0",
    "@types/node": "20.19.34",
    "@types/qs": "6.14.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/react-test-renderer": "18.3.1",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "0.34.6",
    "cheerio": "1.2.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "history": "5.3.0",
    "husky": "9.1.7",
    "jsdom": "22.1.0",
    "marked": "9.1.6",
    "msw": "1.3.5",
    "node-html-parser": "6.1.13",
    "prettier": "3.8.1",
    "react-test-renderer": "18.3.1",
    "rollup-plugin-visualizer": "5.14.0",
    "swagger-typescript-api": "13.2.18",
    "typescript": "5.9.3",
    "validate-branch-name": "1.3.2",
    "vite": "6.4.2",
    "vitest": "0.34.6"
  },
  "validate-branch-name": {
    "pattern": "^(feature|release|hotfix|bugfix|refactor|performance|docs|build|ci|chore)/[A-Z]+-[0-9]+_.+$",
    "errorMsg": "You need to follow this branching name rule: <type>/<JIRA_KEY>_<description>"
  }
}
